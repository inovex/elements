---
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
---

<div
  id="maintenance-banner"
  role="alert"
  aria-label={t.maintenance.label}
  class="sticky top-0 z-50 bg-warning text-stone-900"
>
  <div class="max-w-5xl mx-auto px-6 h-10 flex justify-center items-center gap-3">
    <p class="text-sm font-medium text-center">{t.maintenance.message}</p>
      <button
        id="maintenance-banner-dismiss"
        aria-label={t.maintenance.dismiss}
        class="cursor-pointer shrink-0 rounded p-1 hover:bg-warning-light"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
  </div>
</div>

<script>
  const banner = document.getElementById('maintenance-banner');
  const btn = document.getElementById('maintenance-banner-dismiss');

  btn?.addEventListener('click', () => {
    banner?.remove();
  });
</script>
